# direnv configuration — https://direnv.net
# Requires nix-direnv (https://github.com/nix-community/nix-direnv) for fast,
# cached flake dev shells. Run `direnv allow` once to enable.

# Re-enter the dev shell whenever the flake or its modules change.
watch_file flake.nix flake.lock nix/devshell.nix nix/package.nix nix/web.nix

use flake

# Load project-local environment (DB creds, admin password, …) if present.
# Copy .env.example to .env to get started; .env is gitignored.
dotenv_if_exists
